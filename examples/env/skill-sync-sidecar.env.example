# Optional when not using --cc-switch-webdav.
SKILL_SYNC_WEBDAV_USER=
SKILL_SYNC_WEBDAV_PASSWORD=

# Local package checkout used by service templates during source-tree runs.
PYTHONPATH=/PATH/TO/skill-sync-sidecar/src

# Automatic sync direction. Desktop peers default to push-pull; OpenClaw should
# normally use pull-only unless it has explicit approval to publish local edits.
SKILL_SYNC_WRITER_POLICY=push-pull
